#version 450

struct Gaussian {
    vec3 mean;        
    float pad1;
    vec4 scaleOpacity; 
    vec4 rot;          // quaternion
    vec3 color;        
    uint gradCount;   // Packed per-iteration contribution count
};

// Adam의 상태를 저장하는 버퍼 (가우시안 개수만큼 할당)
struct AdamState {
    vec4 posR_m; // pos + color.R
    vec4 posR_v;
    vec4 scaleOpacity_m; // scale + opacity
    vec4 scaleOpacity_v;
    vec4 rot_m;
    vec4 rot_v;
    vec2 colorGB_m;
    vec2 colorGB_v;
};

layout(set = 0, binding = 0) buffer Gaussians { Gaussian gaussians[]; };
layout(set = 0, binding = 7) buffer readonly GaussianCounter { uint numGaussians; };
layout(set = 1, binding = 8) buffer Gradients { Gaussian grads[]; };
layout(set = 1, binding = 10) buffer AdamMoms { AdamState moms[]; }; // m, v 저장

layout(push_constant) uniform PushConstant {
    // Adam params
    float pos_lr;       
    float rot_lr;
    float scale_lr;
    float opacity_lr;
    float color_lr;

    float beta1;        // 보통 0.9
    float beta2;        // 보통 0.999
    float epsilon;      // 보통 1e-8
    uint  step;         // 현재 트레이닝 스텝 (1부터 시작)
} p;

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

vec4 updateAdam4(vec4 g, inout vec4 m, inout vec4 v, float m_corr, float v_corr, vec4 lr) {
    m = p.beta1 * m + (1.0 - p.beta1) * g;
    v = p.beta2 * v + (1.0 - p.beta2) * (g * g);
    vec4 m_hat = m / m_corr;
    vec4 v_hat = v / v_corr;
    return (lr * m_hat) / (sqrt(v_hat) + p.epsilon);
}

vec2 updateAdam2(vec2 g, inout vec2 m, inout vec2 v, float m_corr, float v_corr, vec2 lr) {
    m = p.beta1 * m + (1.0 - p.beta1) * g;
    v = p.beta2 * v + (1.0 - p.beta2) * (g * g);
    vec2 m_hat = m / m_corr;
    vec2 v_hat = v / v_corr;
    return (lr * m_hat) / (sqrt(v_hat) + p.epsilon);
}

void main() {
    uint gIdx = gl_GlobalInvocationID.x;
    if (gIdx >= numGaussians) return;

    Gaussian param = gaussians[gIdx];

    // NaN Protection: If any parameter is NaN, reset and skip
    if (any(isnan(param.mean)) || any(isnan(param.scaleOpacity)) || any(isnan(param.rot)) || any(isnan(param.color))) {
        gaussians[gIdx].mean = vec3(0.0);
        gaussians[gIdx].scaleOpacity = vec4(0.0, 0.0, 0.0, -10.0); // Transparent
        gaussians[gIdx].rot = vec4(0.0, 0.0, 0.0, 1.0);
        gaussians[gIdx].color = vec3(0.0);
        return;
    }

    // 1. Bias correction factors
    float m_corr = 1.0 - pow(p.beta1, float(p.step));
    float v_corr = 1.0 - pow(p.beta2, float(p.step));

    // 2. Load gradients (use raw accumulated gradients, NOT averaged)
    // Original 3DGS does NOT normalize by pixel count.
    // Adam's second moment naturally handles gradient magnitude.
    Gaussian grad = grads[gIdx];

    AdamState mom = moms[gIdx];

    // 3. Pack parameters and gradients
    vec4 grad_posR = vec4(grad.mean, grad.color.r);
    vec4 grad_scaleOpacity = grad.scaleOpacity;
    vec4 grad_rot = grad.rot;
    vec2 grad_colorGB = vec2(grad.color.g, grad.color.b);

    vec4 param_posR = vec4(param.mean, param.color.r);
    vec4 param_scaleOpacity = param.scaleOpacity;
    vec4 param_rot = param.rot;
    vec2 param_colorGB = vec2(param.color.g, param.color.b);

    // 4. Update
    vec4 posR_lr = vec4(vec3(p.pos_lr), p.color_lr);
    
    // Safety check: Skip update if gradients are invalid
    if (any(isnan(grad_posR)) || any(isinf(grad_posR)) ||
        any(isnan(grad_scaleOpacity)) || any(isinf(grad_scaleOpacity)) ||
        any(isnan(grad_rot)) || any(isinf(grad_rot)) ||
        any(isnan(grad_colorGB)) || any(isinf(grad_colorGB))) {
        // Just reset gradients and skip update
        grads[gIdx].mean = vec3(0.0);
        grads[gIdx].scaleOpacity = vec4(0.0);
        grads[gIdx].rot = vec4(0.0);
        grads[gIdx].color = vec3(0.0);
        grads[gIdx].gradCount = 0u;
        return;
    }

    param_posR -= updateAdam4(grad_posR, mom.posR_m, mom.posR_v, m_corr, v_corr, posR_lr);
    
    vec4 scaleOpacity_lr = vec4(vec3(p.scale_lr), p.opacity_lr);
    param_scaleOpacity -= updateAdam4(grad_scaleOpacity, mom.scaleOpacity_m, mom.scaleOpacity_v, m_corr, v_corr, scaleOpacity_lr);
    
    param_rot -= updateAdam4(grad_rot, mom.rot_m, mom.rot_v, m_corr, v_corr, vec4(p.rot_lr));
    
    param_colorGB -= updateAdam2(grad_colorGB, mom.colorGB_m, mom.colorGB_v, m_corr, v_corr, vec2(p.color_lr));

    // Clamp color to [0, 1]
    param_posR.w = clamp(param_posR.w, 0.0, 1.0);
    param_colorGB = clamp(param_colorGB, vec2(0.0), vec2(1.0));
    
    // Normalize quaternion
    float len_rot = length(param_rot);
    if (len_rot > 0.0) {
        param_rot /= len_rot;
    } else {
        param_rot = vec4(0.0, 0.0, 0.0, 1.0);
    }

    // Clamp scales to prevent explosion (log-space clamping)
    // -10.0 to 5.0 is a typical range for log-scale
    param_scaleOpacity.xyz = clamp(param_scaleOpacity.xyz, vec3(-15.0), vec3(5.0));

    // 5. Unpack and write back parameters
    param.mean = param_posR.xyz;
    param.scaleOpacity = param_scaleOpacity;
    param.rot = param_rot;
    param.color = vec3(param_posR.w, param_colorGB.x, param_colorGB.y);
    
    gaussians[gIdx] = param;

    // 6. Write back moments
    moms[gIdx] = mom;

    // 7. Reset gradients for next iteration
    grads[gIdx].mean = vec3(0.0);
    grads[gIdx].scaleOpacity = vec4(0.0);
    grads[gIdx].rot = vec4(0.0);
    grads[gIdx].color = vec3(0.0);
    grads[gIdx].gradCount = 0u;
}