// second argument pass shader which is only used in train loop

#version 450

layout(set = 0, binding = 6) buffer writeonly IndirectArgs { uint x; uint y; uint z; };
layout(set = 0, binding = 7) buffer readonly GaussianCounter { uint count; };

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

void main() {
    x = (count + 255) / 256;
    y = 1;
    z = 1;
}